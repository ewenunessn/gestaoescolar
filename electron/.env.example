# Configurações do Backend (copiar do backend/.env)
DATABASE_URL=postgresql://usuario:senha@host.neon.tech/database?sslmode=require
JWT_SECRET=sua_chave_secreta_aqui
NODE_ENV=production

# Porta do backend (padrão: 3000)
PORT=3000

# GitHub Token para auto-update (opcional)
# Obter em: https://github.com/settings/tokens
# GH_TOKEN=seu_token_github_aqui
