# Banco de Dados
# Para produção (Neon/Vercel), use sslmode=verify-full para máxima segurança
# Exemplo: postgresql://user:pass@host/db?sslmode=verify-full
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/alimentacao_escolar
DATABASE_SSL=false

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Redis (Opcional - se não configurado, usa cache em memória)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# Servidor
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Logs
LOG_LEVEL=info

# AWS S3 (Opcional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=

# Sentry (Opcional)
# SENTRY_DSN=

# Vercel
VERCEL=0
